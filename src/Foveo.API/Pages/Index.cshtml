@page
@model IndexModel
@inject IOptions<WeddingOptions> WeddingOpts
@{
    var w = WeddingOpts.Value;
    ViewData["Title"] = $"{w.CoupleFirst} & {w.CoupleSecond}";
}

<main class="landing">
    <span class="mono hero-date fade-up" style="--d:0">@w.EventDate — @w.Venue</span>
    <h1 class="fade-up" style="--d:1">@w.CoupleFirst <span class="amp">&amp;</span> @w.CoupleSecond</h1>

    <div class="fade-up" style="--d:2">
        <svg class="rope" viewBox="0 0 340 24" aria-hidden="true">
            <path d="M6,12 Q90,3 170,12 T334,12" />
            <circle cx="170" cy="12" r="3.2" />
            <circle cx="12" cy="12" r="2.4" />
            <circle cx="328" cy="12" r="2.4" />
        </svg>
    </div>

    <span class="mono landing-tag fade-up" style="--d:3">@w.Tagline</span>

    <div class="hero-actions fade-up" style="--d:4">
        <a class="hero-btn" asp-page="/Album">Se albummet</a>
        <a class="hero-btn hero-btn-outline" asp-page="/Upload">Upload billede</a>
    </div>
</main>
