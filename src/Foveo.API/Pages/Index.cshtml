@page
@using Foveo.Domain.Aggregates
@model IndexModel
@{
    ViewData["Title"] = "Gallery";
    var gallery = Model.Gallery;
}

<section class="page-intro">
    <h1>The gallery</h1>
    <p>Every photo and video you've all shared, in one place.</p>
</section>

@if (gallery.TotalItems == 0)
{
    <div class="empty-state">
        <p class="empty-mark">✦</p>
        <h2>No photos yet</h2>
        <p>Be the first to add a memory.</p>
        <a class="button" asp-page="/Upload">Add photos</a>
    </div>
}
else
{
    <div class="gallery-grid">
        @foreach (var item in gallery.Items)
        {
            <button type="button" class="tile @(item.Type == MediaType.Video ? "tile-video" : "")"
                    data-type="@item.Type" data-src="@item.DisplayUrl"
                    aria-label="@(item.UploaderName is null ? "Open media" : $"Open media from {item.UploaderName}")">
                <img src="@item.ThumbnailUrl" loading="lazy" alt="" />
                @if (item.Type == MediaType.Video)
                {
                    <span class="play-badge" aria-hidden="true">▶</span>
                }
                @if (item.UploaderName is not null)
                {
                    <span class="tile-caption">@item.UploaderName</span>
                }
            </button>
        }
    </div>

    @if (gallery.TotalPages > 1)
    {
        <nav class="pager" aria-label="Gallery pages">
            @if (gallery.HasPrevious)
            {
                <a class="pager-link" asp-page="/Index" asp-route-page="@(gallery.Page - 1)">← Newer</a>
            }
            <span class="pager-status">Page @gallery.Page of @gallery.TotalPages</span>
            @if (gallery.HasNext)
            {
                <a class="pager-link" asp-page="/Index" asp-route-page="@(gallery.Page + 1)">Older →</a>
            }
        </nav>
    }
}

<div class="lightbox" id="lightbox" hidden>
    <button type="button" class="lightbox-close" id="lightbox-close" aria-label="Close">✕</button>
    <div class="lightbox-content" id="lightbox-content"></div>
</div>

@section Scripts {
    <script src="~/js/gallery.js" asp-append-version="true"></script>
}
