<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#faf7f2" />
    <title>@ViewData["Title"] · Our Wedding</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a class="brand" asp-page="/Index">
            <span class="brand-mark">✦</span>
            <span class="brand-name">Our Wedding</span>
        </a>
        <nav class="site-nav">
            <a asp-page="/Index">Gallery</a>
            <a class="nav-cta" asp-page="/Upload">Add photos</a>
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <p>Thank you for celebrating with us.</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
