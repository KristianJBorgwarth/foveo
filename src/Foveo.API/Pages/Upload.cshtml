@page
@model UploadModel
@{
    ViewData["Title"] = "Upload billede";
    ViewData["Active"] = "upload";
}

<partial name="_Nav" />

<section class="upload-section">
    <form class="upload-card" id="upload-form">
        <span class="mono">Del jeres minder</span>

        <div class="field">
            <label for="uploader-name">Dit navn</label>
            <input type="text" id="uploader-name" name="uploaderName" maxlength="80" autocomplete="name" placeholder="Sofie Lund" />
        </div>

        <div class="field">
            <label>Billeder &amp; videoer</label>
            <label class="dropzone" for="file-input">
                <div class="dz-title">Tryk for at vælge</div>
                <div class="dz-hint">direkte fra kamerarullen — vi klarer resten</div>
                <input type="file" id="file-input" accept="image/*,video/*" multiple hidden />
            </label>
        </div>

        <ul class="upload-list" id="upload-list"></ul>

        <button type="submit" class="btn" id="upload-button" disabled>Føj til albummet</button>
        <p class="upload-done mono" id="upload-done" hidden>
            Tilføjet! <a asp-page="/Album">Se albummet →</a>
        </p>
    </form>
</section>

@section Scripts {
    <script src="~/js/upload.js" asp-append-version="true"></script>
}
